---
import { Header } from '../components/Header';
import { Contact } from '../components/Contact';
import { Footer } from '../components/Footer';
import { ExitIntentPopup } from '../components/ExitIntentPopup';
import '../styles/global.css';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Contato | Guia do Roçador</title>
    <meta name="description" content="Entre em contato com o Guia do Roçador para tirar dúvidas, parcerias e sugestões de pautas sobre jardinagem." />
  </head>
  <body class="bg-gray-50 flex flex-col min-h-screen m-0 w-full antialiased text-[#1a1a1a]">
    <Header client:load />
    
    <main class="flex-grow">
      {/* Aqui a contact não obriga ter interatividade nativa do react a menos que mude, mas é bom para prevenir caso mude a lógica do form futuramente */}
      <Contact />
    </main>
    
    <Footer />
    
    <ExitIntentPopup client:load />
  </body>
</html>
