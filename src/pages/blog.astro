---
import { Header } from '../components/Header';
import { Blog } from '../components/Blog';
import { Footer } from '../components/Footer';
import { ExitIntentPopup } from '../components/ExitIntentPopup';
import '../styles/global.css';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Blog & Reviews | Guia do Roçador</title>
    <meta name="description" content="Análises técnicas, comparativos detalhados e guias para você escolher a roçadeira certa." />
  </head>
  <body class="bg-gray-50 flex flex-col min-h-screen m-0 w-full antialiased text-[#1a1a1a]">
    <Header client:load />
    
    {/* client:load é importante aqui pois o Blog usa useState para a paginação */}
    <Blog client:load />
    
    <Footer />
    
    <ExitIntentPopup client:load />
  </body>
</html>
