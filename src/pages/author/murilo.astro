---
import { Header } from '../../components/Header';
import { AuthorMurilo } from '../../components/AuthorMurilo';
import { Footer } from '../../components/Footer';
import { CookieConsent } from '../../components/CookieConsent';
import { ExitIntentPopup } from '../../components/ExitIntentPopup';
import '../../styles/global.css';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Murilo | Fundador | Guia do Roçador</title>
    <meta name="description" content="Conheça Murilo, fundador do Guia do Roçador e especialista em SEO e estratégia de conteúdo para equipamentos de jardinagem." />
  </head>
  <body class="bg-gray-50 flex flex-col min-h-screen m-0 w-full antialiased text-[#1a1a1a]">
    <Header client:load />
    
    <main class="flex-grow">
      <AuthorMurilo client:load />
    </main>
    
    <Footer />
    
    <CookieConsent client:load />
    <ExitIntentPopup client:load />
  </body>
</html>
